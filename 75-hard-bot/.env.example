TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
ADMIN_USER_ID=your-telegram-user-id
GROUP_CHAT_ID=set-after-adding-bot-to-group
CHALLENGE_START_DATE=2026-04-15
DATABASE_PATH=data/75hard.db
ANTHROPIC_API_KEY=your-anthropic-api-key

# Roster — comma separated
PARTICIPANTS=Alice,Bob,Carol,Dave,Eve
# Display name of the organizer used in user-facing copy
ORGANIZER=Alice
# Names of users who already paid via other means (skip Venmo step)
ALREADY_PAID=Bob
# Venmo handle for the buy-in deeplink (omit @ prefix)
VENMO_USERNAME=alice-venmo
# Same-day reminder timezones — only listed users get the 10pm DM
USER_TIMEZONES_ET=Carol,Dave
USER_TIMEZONES_PT=Alice,Bob
# Buy-in amount in dollars
BUY_IN=75
